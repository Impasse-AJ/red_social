{% extends 'base.html.twig' %}

{% block title %}Restablecer contraseña · SymSocial{% endblock %}

{% block nav %}{% endblock %}

{% block main_class %}auth-wrap{% endblock %}

{% block body %}
    <div class="auth-card">
        <a class="brand" href="{{ path('landing') }}"><span class="brand-sym">Sym</span>Social</a>
        <h1>Restablecer contraseña</h1>

        {% if error %}
            <div class="alert alert-error">{{ error }}</div>
        {% endif %}

        {% if codigo %}
            <form method="POST" action="{{ path('procesar_restablecimiento') }}">
                <input type="hidden" name="_token" value="{{ csrf_token('restablecer') }}">
                <input type="hidden" name="codigo" value="{{ codigo }}">

                <div class="form-field">
                    <label for="password">Nueva contraseña</label>
                    <input class="input" type="password" id="password" name="password" minlength="8" required autofocus>
                </div>
                <div class="form-field">
                    <label for="confirm_password">Confirmar contraseña</label>
                    <input class="input" type="password" id="confirm_password" name="confirm_password" minlength="8" required>
                </div>
                <button type="submit" class="btn btn-primary btn-block">Restablecer</button>
            </form>
        {% elseif not error %}
            <div class="alert alert-error">El enlace de recuperación no es válido o ha caducado.</div>
        {% endif %}

        <div class="auth-links">
            <a href="{{ path('ctrl_login') }}">Volver al inicio de sesión</a>
        </div>
    </div>
{% endblock %}
