{% extends 'base.html.twig' %}
{% import '_ui.html.twig' as ui %}

{% block title %}Publicación de {{ publicacion.usuario.nombreUsuario }} · SymSocial{% endblock %}

{% block body %}
    <header class="page-header">
        <a class="nav-link" href="{{ path('ver_perfil', { id: publicacion.usuario.id }) }}" title="Volver al perfil">
            {{ ui.icon('arrow-left') }}
        </a>
        <h1>Publicación</h1>
    </header>

    <article class="post">
        <a href="{{ path('ver_perfil', { id: publicacion.usuario.id }) }}">
            {{ ui.avatar(publicacion.usuario, 'avatar-md') }}
        </a>
        <div class="post-body">
            <div class="post-meta">
                <a class="post-author" href="{{ path('ver_perfil', { id: publicacion.usuario.id }) }}">{{ publicacion.usuario.nombreUsuario }}</a>
                <span class="post-date">· {{ publicacion.fechaCreacion|date('d/m/Y H:i') }}</span>
            </div>
            <p class="post-content">{{ publicacion.contenido }}</p>
        </div>
    </article>

    <h2 style="padding-top: 1rem;">Comentarios</h2>

    <ul class="comment-list" id="comentarios-lista">
        {% for comentario in comentarios %}
            <li id="comentario-{{ comentario.id }}" class="comment draggable-comentario" draggable="true">
                {{ ui.avatar(comentario.usuario, 'avatar-sm') }}
                <div class="post-body">
                    <div class="post-meta">
                        <span class="post-author">{{ comentario.usuario.nombreUsuario }}</span>
                        <span class="post-date">· {{ comentario.fechaCreacion|date('d/m/Y H:i') }}</span>
                    </div>
                    <p class="post-content">{{ comentario.contenido }}</p>
                </div>
            </li>
        {% endfor %}
    </ul>

    {% if comentarios is empty %}
        <p id="no-comentarios" class="empty-state">No hay comentarios aún. Sé el primero.</p>
    {% endif %}

    <div class="composer" style="border-bottom: none;">
        {{ ui.avatar(app.user, 'avatar-md') }}
        {% set avatarUrl = app.user.fotoPerfil and app.user.fotoPerfil != 'default-profile-picture.jpg'
            ? asset('uploads/' ~ app.user.fotoPerfil)
            : asset('img/default-avatar.svg') %}
        <form id="comentario-form" method="POST" action="{{ path('comentar_publicacion', { id: publicacion.id }) }}" data-avatar="{{ avatarUrl }}">
            <input type="hidden" name="_token" value="{{ csrf_token('comentar') }}">
            <textarea class="input" id="contenido" name="contenido" maxlength="255" required placeholder="Escribe un comentario..."></textarea>
            <div class="composer-actions">
                <button type="submit" class="btn btn-primary btn-sm">Comentar</button>
            </div>
        </form>
    </div>

    <div id="papelera" class="dropzone" data-csrf="{{ csrf_token('eliminar_comentario') }}">
        Arrastra aquí uno de tus comentarios para eliminarlo
    </div>
{% endblock %}

{% block scripts %}
    <script src="{{ asset('js/comentarios.js') }}"></script>
{% endblock %}
