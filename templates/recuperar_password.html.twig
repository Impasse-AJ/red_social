{% extends 'base.html.twig' %}

{% block title %}Recuperar contraseña · SymSocial{% endblock %}

{% block nav %}{% endblock %}

{% block main_class %}auth-wrap{% endblock %}

{% block body %}
    <div class="auth-card">
        <a class="brand" href="{{ path('landing') }}"><span class="brand-sym">Sym</span>Social</a>
        <h1>Recuperar contraseña</h1>

        {% if error %}
            <div class="alert alert-error">{{ error }}</div>
        {% endif %}

        {% if success %}
            <div class="alert alert-success">{{ success }}</div>
        {% else %}
            <p style="color: var(--text-muted); font-size: .92rem;">
                Escribe tu correo y te enviaremos un enlace para restablecer tu contraseña.
            </p>
            <form action="{{ path('procesar_recuperacion') }}" method="POST">
                <input type="hidden" name="_token" value="{{ csrf_token('recuperar') }}">
                <div class="form-field">
                    <label for="email">Correo electrónico</label>
                    <input class="input" type="email" id="email" name="email" required autofocus>
                </div>
                <button type="submit" class="btn btn-primary btn-block">Enviar enlace</button>
            </form>
        {% endif %}

        <div class="auth-links">
            <a href="{{ path('ctrl_login') }}">Volver al inicio de sesión</a>
        </div>
    </div>
{% endblock %}
