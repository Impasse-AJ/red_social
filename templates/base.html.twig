<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}SymSocial{% endblock %}</title>
    <link rel="stylesheet" href="{{ asset('styles/app.css') }}">
    {% block styles %}{% endblock %}
</head>
<body class="{% block body_class %}{% endblock %}">
{% import '_ui.html.twig' as ui %}

{% block nav %}
    <nav class="navbar">
        <div class="navbar-inner">
            <a class="brand" href="{{ app.user ? path('ctrl_home') : path('landing') }}"><span class="brand-sym">Sym</span>Social</a>

            {% if app.user %}
                {% set pendientes = solicitudes_pendientes() %}
                <div class="nav-links">
                    <a class="nav-link" href="{{ path('ctrl_home') }}" title="Inicio">
                        {{ ui.icon('home') }}<span class="nav-label">Inicio</span>
                    </a>
                    <a class="nav-link" href="{{ path('descubrir') }}" title="Descubrir gente">
                        {{ ui.icon('compass') }}<span class="nav-label">Descubrir</span>
                    </a>
                    <a class="nav-link" href="{{ path('ver_solicitudes') }}" title="Solicitudes de amistad">
                        {{ ui.icon('bell') }}<span class="nav-label">Solicitudes</span>
                        {% if pendientes > 0 %}<span class="badge">{{ pendientes }}</span>{% endif %}
                    </a>
                    <a class="nav-link" href="{{ path('ver_perfil', { id: app.user.id }) }}" title="Mi perfil">
                        {{ ui.icon('user') }}<span class="nav-label">Perfil</span>
                    </a>
                    <a class="nav-link" href="{{ path('ctrl_logout') }}" title="Cerrar sesión">
                        {{ ui.icon('logout') }}
                    </a>
                </div>
            {% else %}
                <div class="nav-links">
                    <a class="btn btn-outline btn-sm" href="{{ path('ctrl_login') }}">Iniciar sesión</a>
                    <a class="btn btn-primary btn-sm" href="{{ path('registro') }}">Registrarse</a>
                </div>
            {% endif %}
        </div>
    </nav>
{% endblock %}

<main class="{% block main_class %}app-shell{% endblock %}">
    {% for label in ['success', 'error', 'info'] %}
        {% for mensaje in app.flashes(label) %}
            <div class="alert alert-{{ label }}">{{ mensaje }}</div>
        {% endfor %}
    {% endfor %}

    {% block body %}{% endblock %}
</main>

{% if app.user %}
    <script src="{{ asset('js/menciones.js') }}"></script>
{% endif %}
{% block scripts %}{% endblock %}
</body>
</html>
