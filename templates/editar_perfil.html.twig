{% extends 'base.html.twig' %}
{% import '_ui.html.twig' as ui %}

{% block title %}Editar perfil · SymSocial{% endblock %}

{% block body %}
    <header class="page-header">
        <a class="nav-link" href="{{ path('ver_perfil', { id: usuario.id }) }}" title="Volver al perfil">
            {{ ui.icon('arrow-left') }}
        </a>
        <h1>Editar perfil</h1>
    </header>

    <div class="card">
        {% if error is defined and error %}
            <div class="alert alert-error">{{ error }}</div>
        {% endif %}

        <form method="POST">
            <input type="hidden" name="_token" value="{{ csrf_token('editar_perfil') }}">
            <div class="form-field">
                <label for="nombre_usuario">Nombre de usuario</label>
                <input class="input" type="text" id="nombre_usuario" name="nombre_usuario" value="{{ usuario.nombreUsuario }}" minlength="3" maxlength="50" required>
            </div>
            <button type="submit" class="btn btn-primary">Guardar cambios</button>
        </form>
    </div>
{% endblock %}
