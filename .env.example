# Plantilla de configuración. Copiar a .env y rellenar con valores reales:
#   cp .env.example .env
#
# El archivo .env NO se versiona: contiene datos sensibles.

###> symfony/framework-bundle ###
# dev en local | prod en la VPS
APP_ENV=dev
# Generar con: php -r "echo bin2hex(random_bytes(16));"
APP_SECRET=
###< symfony/framework-bundle ###

###> doctrine/doctrine-bundle ###
# MySQL del docker-compose del proyecto (contenedor symsocial_mysql)
DATABASE_URL="mysql://symsocial_user:change_me@127.0.0.1:3308/symsocial?serverVersion=8.4&charset=utf8mb4"
###< doctrine/doctrine-bundle ###

###> symfony/messenger ###
MESSENGER_TRANSPORT_DSN=doctrine://default?auto_setup=0
###< symfony/messenger ###

###> symfony/mailer ###
# Remitente de los correos de la aplicación (activación, recuperación...)
MAILER_FROM="no-reply@abrahampauta.com"
# SMTP para correos de activación y recuperación de contraseña (Brevo).
# Ojo: si el login contiene @, codificarla como %40.
MAILER_DSN=
###< symfony/mailer ###

###> despliegue con docker compose (producción) ###
# Estas variables solo las usa docker-compose.yml; en desarrollo local
# (symfony server + contenedor redsocial-mysql) no hacen falta.
MYSQL_DATABASE=symsocial
MYSQL_USER=symsocial_user
MYSQL_PASSWORD=change_me
MYSQL_ROOT_PASSWORD=change_me
MYSQL_PORT=3308
APP_PORT=8090
PHPMYADMIN_PORT=8082
###< despliegue con docker compose (producción) ###
